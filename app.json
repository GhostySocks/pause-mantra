{
  "expo": {
    "name": "Pause Mantra",
    "slug": "pausemantra",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "pausemantra",
    "newArchEnabled": false,
    "splash": {
      "backgroundColor": "#321650"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pausemantra.app",
      "infoPlist": {
        "UIBackgroundModes": ["fetch", "remote-notification"]
      }
    },
    "android": {
      "package": "com.pausemantra.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#321650"
      },
      "edgeToEdgeEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-sqlite",
      "expo-dev-client",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "backgroundColor": "#321650",
          "dark": {
            "backgroundColor": "#321650"
          }
        }
      ]
    ],
    "owner": "ghostysocks",
    "extra": {
      "eas": {
        "projectId": "9017ad21-2227-43fa-9189-3a36c649b4a7"
      }
    }
  }
}
